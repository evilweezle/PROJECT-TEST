{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "A customer or client entity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "Operation": {
      "title": "Operation",
      "description": "A manufacturing or service operation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "defaultEstimatedTimeMinutes": { "type": "number" },
        "color": { "type": "string" }
      },
      "required": ["name"]
    },
    "Part": {
      "title": "Part",
      "description": "A component or part definition.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "operations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "operationId": { "type": "string" },
              "estimatedTimeMinutes": { "type": "number" },
              "dependencies": { "type": "array", "items": { "type": "string" } },
              "delayDays": { "type": "number" }
            }
          }
        }
      },
      "required": ["name"]
    },
    "WorkOrder": {
      "title": "Work Order",
      "description": "A request for work to be performed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "clientId": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "finishDate": { "type": "string", "format": "date" },
        "parts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "partId": { "type": "string" },
              "instanceId": { "type": "string" },
              "operations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "operationId": { "type": "string" },
                    "estimatedTimeMinutes": { "type": "number" },
                    "dependencies": { "type": "array", "items": { "type": "string" } },
                    "delayDays": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["name", "clientId", "startDate"]
    },
    "Employee": {
      "title": "Employee",
      "description": "A staff member.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "skillId": { "type": "string" },
              "certified": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["name"]
    },
    "Team": {
      "title": "Team",
      "description": "A group of employees.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "An assignment of employees to a specific task.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workOrderId": { "type": "string" },
        "partInstanceId": { "type": "string" },
        "operationId": { "type": "string" },
        "employeeIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["workOrderId", "partInstanceId", "operationId"]
    },
    "Skill": {
      "title": "Skill",
      "description": "A technical skill definition.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name"]
    },
    "Material": {
      "title": "Material",
      "description": "A raw material or resource.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "unit": { "type": "string" },
        "stock": { "type": "number" }
      },
      "required": ["name"]
    },
    "NonConformity": {
      "title": "Non-Conformity",
      "description": "A report of a quality issue.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "workOrderId": { "type": "string" },
        "operationId": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "severity": { "type": "string" },
        "reportedDate": { "type": "string", "format": "date" }
      },
      "required": ["workOrderId", "description", "status"]
    }
  },
  "firestore": {
    "clients": { "schema": "Client", "description": "Collection of clients." },
    "operations": { "schema": "Operation", "description": "Collection of operations." },
    "parts": { "schema": "Part", "description": "Collection of parts." },
    "workOrders": { "schema": "WorkOrder", "description": "Collection of work orders." },
    "employees": { "schema": "Employee", "description": "Collection of employees." },
    "teams": { "schema": "Team", "description": "Collection of teams." },
    "assignments": { "schema": "Assignment", "description": "Collection of assignments." },
    "skills": { "schema": "Skill", "description": "Collection of skills." },
    "materials": { "schema": "Material", "description": "Collection of materials." },
    "nonConformities": { "schema": "NonConformity", "description": "Collection of non-conformities." }
  }
}
